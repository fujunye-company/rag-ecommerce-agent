# ============================================
# AI全栈挑战赛 - 电商AI导购系统 .env.example
# 复制此文件为 .env 并填写实际值
# ============================================

# --- LLM API (必填) ---
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
EMBEDDING_MODEL=text-embedding-3-small

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://shopping:shopping123@localhost:5432/shopping_agent
POSTGRES_USER=shopping
POSTGRES_PASSWORD=shopping123
POSTGRES_DB=shopping_agent
POSTGRES_PORT=5432

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=products

# --- FastAPI ---
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["*"]
