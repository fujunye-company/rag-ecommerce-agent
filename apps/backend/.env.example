# ============================================
# AI全栈挑战赛 - 电商AI导购系统 环境配置模板
# 复制此文件为 .env 并填入真实 API Key
# ============================================

# --- Doubao API (比赛提供 — LLM 主用) ---
DOUBAO_API_KEY=your-doubao-key-here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/
LLM_MODEL=ep-20260514111645-lmgt2
DOUBAO_TPM=800000

# --- DeepSeek API (降级备用) ---
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- Embedding ---
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://shopping:shopping123@localhost:5432/shopping_agent

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=products

# --- FastAPI ---
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["*"]
