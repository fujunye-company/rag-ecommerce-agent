# ============================================
# AI全栈挑战赛 - 电商AI导购系统 环境配置
# ============================================

# --- Doubao API (比赛提供 — LLM 主用) ---
DOUBAO_API_KEY=***     
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/
DOUBAO_MODEL=ep-20260514111645-lmgt2
DOUBAO_TPM=800000

# --- DeepSeek API (降级备用) ---
DEEPSEEK_API_KEY=***     
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- Embedding ---
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# --- OpenAI (备用) ---
OPENAI_API_KEY=***
OPENAI_BASE_URL=https://api.openai.com/v1

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://shopping:shopping123@localhost:5432/shopping_agent
POSTGRES_USER=shopping
POSTGRES_PASSWORD=shopping123
POSTGRES_DB=shopping_agent
POSTGRES_PORT=5432

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=products

# --- FastAPI ---
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["*"]
MAX_UPLOAD_SIZE_MB=10

# --- Docker (镜像源) ---
DOCKER_REGISTRY=docker.m.daocloud.io
